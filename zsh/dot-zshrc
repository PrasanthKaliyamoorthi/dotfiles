# ~/.zshrc or ~/.zprofile
if command -v tmux >/dev/null 2>&1; then
  if [[ -t 1 && -z "$TMUX" ]]; then
    sessions=$(tmux list-sessions -F "#{session_name}" 2>/dev/null)

    if [[ -n "$sessions" ]]; then
      echo
      echo "Available tmux sessions:"
      echo "$sessions" | nl -w2 -s'. '
      echo
      printf "[a] attach / [n] new / [q] quit: "
      read -k 1 choice < /dev/tty
      echo

      case "$choice" in
        a|A)
          printf "Enter session number or name: "
          read session < /dev/tty
          if [[ "$session" =~ ^[0-9]+$ ]]; then
            # numeric selection
            sel=$(echo "$sessions" | sed -n "${session}p")
            exec tmux attach -t "$sel"
          else
            exec tmux attach -t "$session"
          fi
          ;;
        n|N)
          printf "New session name: "
          read session < /dev/tty
          exec tmux new -s "${session:-new}"
          ;;
        q|Q)
          ;; # drop into plain shell
        *)
          ;; # default: do nothing
      esac
    else
      exec tmux new -s default
    fi
  fi
fi

